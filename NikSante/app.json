{
  "expo": {
    "name": "NikSanté",
    "slug": "niksante",
    "version": "1.4.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "niksante",
    "userInterfaceStyle": "automatic",
    "description": "Application mobile gratuite de suivi du diabète : enregistrement de glycémie, scanner alimentaire IA, suivi du sommeil, rappels de mesure, tableaux de bord et conseils d'urgence hypoglycémie / hyperglycémie.",
    "keywords": [
      "diabète",
      "glycémie",
      "suivi diabète",
      "hypoglycémie",
      "hyperglycémie",
      "santé",
      "insuline"
    ],
    "primaryColor": "#388E3C",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.niksante.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "NikSanté utilise la caméra pour scanner vos aliments.",
        "NSPhotoLibraryUsageDescription": "NikSanté peut accéder à vos photos pour analyser vos aliments."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.niksante.app",
      "versionCode": 30,
      "googleServicesFile": "./google-services.json",
      "newArchEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.WAKE_LOCK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "NikSanté – Suivi de Glycémie & Diabète",
      "shortName": "NikSanté",
      "description": "Application mobile gratuite de suivi du diabète : glycémie, scanner alimentaire IA, rappels et conseils d'urgence.",
      "themeColor": "#388E3C",
      "backgroundColor": "#f5f5f5",
      "lang": "fr"
    },
    "plugins": [
      "expo-router",
      "./plugins/withCameraProguard",
      "./plugins/withAlarmScheduler",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#388E3C",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "NikSanté"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "NikSanté utilise la caméra pour scanner vos aliments.",
          "enableMicrophonePermission": false,
          "enableFrameProcessors": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#388E3C",
          "android": {
            "image": "./assets/images/splash-niksante.png",
            "resizeMode": "cover"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5433c0d6-40a8-4b81-9dd1-8d74ed9df387"
      }
    },
    "owner": "supportniksante"
  }
}
