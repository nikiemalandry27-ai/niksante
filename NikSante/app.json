{
  "expo": {
    "name": "NikSanté – Diabète & Glycémie",
    "slug": "niksante",
    "version": "1.2.9",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "niksante",
    "userInterfaceStyle": "automatic",
    "description": "Application mobile gratuite de suivi du diabète : enregistrement de glycémie, scanner alimentaire IA, mesure de fréquence cardiaque, rappels de mesure, tableaux de bord et conseils d'urgence hypoglycémie / hyperglycémie.",
    "keywords": [
      "diabète",
      "glycémie",
      "suivi diabète",
      "hypoglycémie",
      "hyperglycémie",
      "santé",
      "insuline"
    ],
    "primaryColor": "#388E3C",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.niksante.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "NikSanté utilise la caméra pour scanner vos aliments et calculer leur impact glycémique.",
        "NSPhotoLibraryUsageDescription": "NikSanté peut accéder à vos photos pour analyser vos aliments."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.niksante.app",
      "versionCode": 24,
      "googleServicesFile": "./google-services.json",
      "newArchEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "NikSanté – Suivi de Glycémie & Diabète",
      "shortName": "NikSanté",
      "description": "Application mobile gratuite de suivi du diabète : glycémie, scanner alimentaire IA, rappels et conseils d'urgence.",
      "themeColor": "#388E3C",
      "backgroundColor": "#f5f5f5",
      "lang": "fr"
    },
    "plugins": [
      "expo-router",
      "./plugins/withCameraProguard",
      "./plugins/withBrightnessPlugin",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "NikSanté utilise la caméra pour scanner vos aliments et mesurer votre fréquence cardiaque.",
          "enableMicrophonePermission": false,
          "enableFrameProcessors": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#388E3C",
          "android": {
            "image": "./assets/images/splash-niksante.png",
            "resizeMode": "cover"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ba5142f5-0308-47bb-b9a8-f4d6777002ce"
      }
    },
    "owner": "relwende"
  }
}
